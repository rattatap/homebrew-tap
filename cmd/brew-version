#!/bin/sh
#:  * `version` *formula* [...]
#:
#:Show all available and installed versions of *formula*.

set -fue

if [ -z "$*" ]; then
  brew version -h
  exit 1
fi

JQ_NFO='.[] |
{
  name:             .name,
  version:          .versions.stable,
  versioned:        (.versioned_formulae | length) > 0,
  installed:        [.installed[].version],
  other_versions_s: "\n\(.versioned_formulae | join(" "))",
  disabled_s: "\(
    if .disabled then
      " [Disabled]"
    elif .deprecated then
      " [Deprecated]"
    else
      ""
    end
  )",
} |
.installed_s = "\(
  if (.installed | length == 1) and .installed[0] == .version then
    " (Installed)"
  elif (.installed | length) > 0 then
    " (Installed: \(.installed | join(",")))"
  else
    ""
  end
)"'

# check if formula is linked, print appropriate text
link_flag (){
  [ -h "$HOMEBREW_PREFIX/var/homebrew/linked/${1}" ] && echo " [Linked]"
}

PRINT=1

brew info -j "$@" | jq -r "$JQ_NFO"'| "\(.name) \(.version)\(.installed_s)\(.disabled_s)\(if .versioned then .other_versions_s else "" end)"' | while read -r p
do
  if [ -n "$PRINT" ]; then
    echo "${p}$(link_flag "${p%% *}")"
    PRINT=
  else
    if [ -n "$p" ]; then
      brew info -j $p | jq -r "$JQ_NFO"'| "\(.name) \(.version)\(.installed_s)\(.disabled_s)"' | while read -r p
      do
        echo "${p}$(link_flag "${p%% *}")"
      done
    fi
    PRINT=1
  fi
done
