#!/bin/sh
#:  * `version` *formula* [...]
#:
#:Show all available and installed versions of *formula*.

set -fue

if [ -z "$*" ]; then
  brew version -h
  exit 1
fi

JQ_INFO='.[] |'\
'"\(.name) \(.versions.stable)'\
'\(if .disabled then " [Disabled]" else if .deprecated then " [Deprecated]" else "" end end)'\
'\([.installed[].version] | if length > 0 then " (Installed: \(join(", ")))" else "" end )
\(.versioned_formulae | join(" "))"'

JQ_INFO_SHORT='.[] |'\
'"\(.name) \(.versions.stable)'\
'\(if .disabled then " [Disabled]" else if .deprecated then " [Deprecated]" else "" end end)'\
'\([.installed[].version] | if length > 0 then " (Installed: \(join(", ")))" else "" end )"'

PRINT=1

brew info -j "$@" | jq -r "$JQ_INFO" | while read -r p
do
  if [ -n "$PRINT" ]; then
    echo "$p"
    PRINT=
  else
    if [ -n "$p" ]; then
      brew info -j $p | jq -r "$JQ_INFO_SHORT"
    fi
    PRINT=1
  fi
done
